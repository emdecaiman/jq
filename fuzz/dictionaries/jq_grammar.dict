# ---------- keywords ----------
"def"
"if"
"then"
"else"
"elif"
"end"
"and"
"or"
"not"
"as"
"reduce"
"foreach"
"try"
"catch"
"label"
"break"
"module"
"import"
"include"

# ---------- literals ----------
"true"
"false"
"null"

# ---------- variable / binding ----------
"$"
"$x"
"$var"
"$a"
"$b"

# ---------- punctuation ----------
"{"
"}"
"["
"]"
"("
")"
":"
";"
","
"."
".."
"?"
"::"

